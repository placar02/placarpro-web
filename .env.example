# =============================================================================
# PLACARPRO-WEB - VARIÁVEIS DE AMBIENTE
# =============================================================================
# Copie este arquivo para .env.local (para desenvolvimento) ou configure
# diretamente no painel da Vercel (para produção).
# NUNCA comita arquivos .env contendo valores reais no repositório.
# =============================================================================

# =============================================================================
# 1. URL DA API BACKEND
# =============================================================================

# URL base da API (sem /api no final)
# Desenvolvimento local:
NEXT_PUBLIC_API_URL=http://localhost:3000

# Produção (Render):
# NEXT_PUBLIC_API_URL=https://seu-backend.onrender.com

# =============================================================================
# 2. CONFIGURAÇÕES OPCIONAIS DO FRONTEND
# =============================================================================

# Habilita modo de desenvolvimento com sourcemaps
# NEXT_PUBLIC_ENABLE_DEBUG=false

# Versão do app (para cache busting)
# NEXT_PUBLIC_APP_VERSION=1.0.0
